{
  "name": "@hexlet/pairs",
  "version": "2.0.1",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./index": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "type": "module",
  "engines": {
    "node": ">=26.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "documentation": "documentation build src/index.ts -f md",
    "test": "vitest run --pool=threads",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexlet-components/js-pairs.git"
  },
  "author": "Kirill Mokevnin",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hexlet-components/js-pairs/issues"
  },
  "homepage": "https://github.com/hexlet-components/js-pairs#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "documentation": "^14.0.3",
    "npm-check-updates": "^22.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.15"
  }
}
